{
  "version": 2,
  "name": "meeting-prep",
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "**/*.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
